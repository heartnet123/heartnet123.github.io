---
import "../assets/app.css";

export interface Props {
  name: string;
  desc?: string;
  skill1?: string;
  skill2?: string;
  skill3?: string;
  github?: string;
  image?: string;
  /** When provided the card links to /projects/[slug] instead of directly to github */
  slug?: string;
}

const { name, desc, skill1, skill2, skill3, github, image, slug } = Astro.props;

const skills = [skill1, skill2, skill3].filter((skill) => skill);
const href = slug ? `/projects/${slug}` : github;
const isExternal = !slug;
---

<a
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener noreferrer" : undefined}
  class="block group"
>
  <div
    class="bg-[#111] rounded-2xl overflow-hidden border border-white/5 hover:border-white/10 transition-all duration-300 hover:-translate-y-1 gsap-reveal gsap-up"
  >
    {/* Image Container */}
    <div class="relative h-48 overflow-hidden">
      {
        image && (
          <img
            src={image}
            alt={name}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        )
      }
      <div
        class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors duration-300"
      >
      </div>
    </div>

    {/* Content */}
    <div class="p-6 space-y-4">
      <h3
        class="text-xl font-bold text-white group-hover:text-green-400 transition-colors"
      >
        {name}
      </h3>

      <p class="text-gray-400 text-sm leading-relaxed line-clamp-2">
        {desc}
      </p>

      {/* Tags */}
      {
        skills.length > 0 && (
          <div class="flex flex-wrap gap-2 pt-2">
            {skills.map((skill) => (
              <span class="px-3 py-1 text-xs font-mono text-gray-300 bg-white/5 border border-white/10 rounded-md">
                {skill}
              </span>
            ))}
          </div>
        )
      }

      {/* View details indicator */}
      {slug && (
        <div class="flex items-center gap-1 text-xs text-green-500/70 group-hover:text-green-400 transition-colors pt-1">
          <span>View details</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </div>
      )}
    </div>
  </div>
</a>
