---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getReadingTime, formatReadingTime } from "../lib/readingTime";

const allPosts = await getCollection("blog");

// Sort by date descending (newest first)
const posts = allPosts.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Collect all unique tags
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<Layout
    title="Blog | NXLVL"
    description="Mechanical analysis, narrative structures, and the intersection of interactive and sequential art."
>
    <!-- Custom Style Injection -->
    <style is:inline>
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;600&display=swap');
            
        .font-mono-custom {
            font-family: 'JetBrains Mono', monospace;
        }

        .font-sans-custom {
            font-family: 'Space Grotesk', sans-serif;
        }

        /* Custom scrollbar for an editorial feel */
        ::-webkit-scrollbar {
            width: 4px;
            height: 4px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: oklch(var(--bc) / 0.2);
            border-radius: 2px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: oklch(var(--bc) / 0.4);
        }

        /* Hide scrollbar for horizontal navs */
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        /* Subtle grid background */
        .bg-grid {
            background-image: 
                linear-gradient(to right, oklch(var(--bc) / 0.03) 1px, transparent 1px),
                linear-gradient(to bottom, oklch(var(--bc) / 0.03) 1px, transparent 1px);
            background-size: 32px 32px;
        }

        /* Specific NXLVL overrides refined for Forest theme */
        .nxlvl-card {
            background-color: oklch(var(--b2) / 0.5);
            border-color: oklch(var(--bc) / 0.1);
        }
        .nxlvl-card:hover {
            background-color: oklch(var(--b2) / 0.8);
            border-color: oklch(var(--p) / 0.3);
        }
        
        .tab-active {
            background-color: oklch(var(--p));
            color: oklch(var(--pc));
        }
    </style>

    <!-- Iconify Script -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

    <div class="min-h-screen bg-base-200 bg-grid selection:bg-primary/20 selection:text-primary flex flex-col font-sans-custom text-base-content">
        
        <!-- Main Content Area -->
        <div class="max-w-5xl w-full mx-auto px-6 py-8 md:py-12 flex flex-col gap-10">
          
            <div class="flex flex-col gap-10">
                <!-- Header Area -->
                <header class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-base-content/10 pb-8 gsap-reveal gsap-up">
                    <div class="flex flex-col gap-4 max-w-2xl">
                        <div class="flex items-center gap-3">
                            <span class="text-[10px] font-mono-custom text-primary uppercase tracking-widest px-2 py-0.5 border border-primary/30 rounded bg-primary/5">
                                Archive v2.0.4
                            </span>
                        </div>
                        <h1 class="text-4xl md:text-5xl tracking-tight font-bold text-base-content">
                            Transmissions
                        </h1>
                        <p class="text-sm font-mono-custom text-base-content/60 leading-relaxed">
                            {posts.length} entries on mechanical analysis, narrative structures, and the intersection of interactive and sequential art.
                        </p>
                        
                        <!-- Tags Filter -->
                        <div class="flex flex-wrap gap-2 mt-2">
                            {allTags.map((tag) => (
                                <a
                                    href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, "-")}`}
                                    class="px-3 py-1 rounded border border-base-content/10 text-xs font-mono-custom text-base-content/60 hover:border-primary/50 hover:text-primary transition-colors bg-base-100/30"
                                >
                                    #{tag.toLowerCase().replace(/\s+/g, "")}
                                </a>
                            ))}
                        </div>
                    </div>

                    <!-- Custom Toggle (Tabs) -->
                    <div class="flex items-center p-1 rounded border border-base-content/10 bg-base-100/40 w-max h-fit">
                        <button
                            class="px-5 py-1.5 rounded text-xs font-mono-custom font-medium transition-all tab-active"
                            id="tab-latest"
                        >
                            Latest
                        </button>
                        <button
                            class="px-5 py-1.5 rounded text-xs font-mono-custom font-medium transition-all text-base-content/50 hover:text-base-content"
                            id="tab-trending"
                        >
                            Trending
                        </button>
                    </div>
                </header>

                <!-- Posts Feed -->
                <div class="flex flex-col gap-6" id="posts-container">
                    {posts.map((post, i) => {
                        const readingTime = getReadingTime(post.body ?? "");
                        const formattedDate = post.data.date.toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        });
                        const isoDate = post.data.date.toISOString();

                        return (
                            <article
                                class="group relative p-6 md:p-8 rounded border border-base-content/10 bg-base-100/20 hover:bg-base-100/40 hover:border-primary/30 transition-all duration-500 flex flex-col gap-5 overflow-hidden cursor-pointer gsap-reveal gsap-up"
                                style={`transition-delay: ${i * 50}ms`}
                                data-post-id={post.slug}
                            >
                                <!-- Subtle hover gradient slider -->
                                <div
                                    class="absolute inset-0 bg-gradient-to-r from-primary/0 via-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-700 pointer-events-none -translate-x-full group-hover:translate-x-full"
                                    style="transition-property: opacity, transform;"
                                />

                                <!-- Top Meta -->
                                <div class="flex flex-wrap items-center justify-between gap-4 relative z-10">
                                    <div class="flex items-center gap-3">
                                        <div class="w-6 h-6 rounded flex items-center justify-center bg-base-300 text-base-content/60 text-xs font-mono-custom font-medium tracking-tighter">
                                            {post.data.title.charAt(0)}
                                        </div>
                                        <span class="text-xs font-mono-custom text-base-content/60">
                                            Admin
                                        </span>
                                        <span class="text-base-content/20">/</span>
                                        <time datetime={isoDate} class="text-xs font-mono-custom text-base-content/40">
                                            {formattedDate}
                                        </time>
                                    </div>

                                    <div class="flex items-center gap-4 text-xs font-mono-custom text-base-content/40">
                                        <span class="flex items-center gap-1.5">
                                            <iconify-icon icon="solar:clock-circle-linear" stroke-width="1.5"></iconify-icon>
                                            {formatReadingTime(readingTime)}
                                        </span>
                                    </div>
                                </div>

                                <!-- Content -->
                                <div class="flex flex-col gap-3 relative z-10">
                                    <h2 class="text-2xl md:text-3xl tracking-tight font-semibold text-base-content group-hover:text-primary transition-colors duration-300">
                                        <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                                    </h2>
                                    <p class="text-sm font-mono-custom text-base-content/60 leading-relaxed max-w-3xl">
                                        {post.data.description}
                                    </p>
                                </div>

                                <!-- Bottom Meta / Actions -->
                                <div class="flex flex-wrap items-center justify-between gap-4 mt-2 border-t border-base-content/5 pt-5 relative z-10">
                                    <div class="flex flex-wrap gap-2">
                                        {post.data.tags.map((tag) => (
                                            <span
                                                class="px-2 py-1 rounded-sm bg-base-300/50 border border-base-content/5 text-xs font-mono-custom text-base-content/60"
                                            >
                                                <iconify-icon icon="solar:hashtag-linear" class="mr-1 opacity-50"></iconify-icon>
                                                {tag}
                                            </span>
                                        ))}
                                    </div>

                                    <div class="flex items-center gap-4">
                                        <button class="flex items-center gap-2 text-xs font-mono-custom text-primary hover:text-primary/80 transition-colors group-hover:translate-x-1 duration-300">
                                            <a href={`/blog/${post.slug}`}>Access Record</a>
                                            <iconify-icon icon="solar:arrow-right-up-linear" stroke-width="1.5"></iconify-icon>
                                        </button>
                                    </div>
                                </div>
                            </article>
                        );
                    })}
                </div>

                <!-- Pagination Placeholder -->
                <div class="mt-4 flex items-center justify-between border-t border-base-content/10 pt-8 text-xs font-mono-custom text-base-content/40 gsap-reveal gsap-up">
                    <button class="hover:text-base-content transition-colors flex items-center gap-2 disabled:opacity-50" disabled>
                        <iconify-icon icon="solar:arrow-left-linear" stroke-width="1.5"></iconify-icon>
                        Prev
                    </button>
                    <span>Page 1 / 1</span>
                    <button class="hover:text-base-content transition-colors flex items-center gap-2 disabled:opacity-50" disabled>
                        Next
                        <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5"></iconify-icon>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Client-side Logic -->
    <script>
        const tabLatest = document.getElementById('tab-latest');
        const tabTrending = document.getElementById('tab-trending');

        if (tabLatest && tabTrending) {
            tabLatest.addEventListener('click', () => {
                tabLatest.classList.add('tab-active');
                tabLatest.classList.remove('text-base-content/50');
                tabTrending.classList.remove('tab-active');
                tabTrending.classList.add('text-base-content/50');
            });

            tabTrending.addEventListener('click', () => {
                tabTrending.classList.add('tab-active');
                tabTrending.classList.remove('text-base-content/50');
                tabLatest.classList.remove('tab-active');
                tabLatest.classList.add('text-base-content/50');
            });
        }

        // Add redirection to articles on card click
        const articles = document.querySelectorAll('article[data-post-id]');
        articles.forEach(article => {
            article.addEventListener('click', (e) => {
                // If it's a click on a link inside, let the link handle it
                if ((e.target as HTMLElement).closest('a')) return;
                
                const slug = article.getAttribute('data-post-id');
                if (slug) {
                    window.location.href = `/blog/${slug}`;
                }
            });
        });
    </script>
</Layout>
