---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getReadingTime, formatReadingTime } from "../lib/readingTime";

const allPosts = await getCollection("blog");

// Sort by date descending (newest first)
const posts = allPosts.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Collect all unique tags
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<Layout
    title="Blog"
    description="Thoughts on web development, TypeScript, React, and building for the modern web."
>
    <div class="min-h-screen bg-base-200 pt-24 px-6 pb-12">
        <div class="container mx-auto max-w-4xl">
            <!-- Header -->
            <div class="mb-10 gsap-reveal gsap-up">
                <h1 class="text-5xl font-bold text-primary mb-3">Blog</h1>
                <p class="text-base-content/60 text-lg">
                    {posts.length} post{posts.length !== 1 ? "s" : ""} on web
                    development, tooling, and software craft.
                </p>
            </div>

            <!-- Tag filter chips -->
            {
                allTags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-8 gsap-reveal gsap-up">
                        {allTags.map((tag) => (
                            <a
                                href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, "-")}`}
                                class="badge badge-outline badge-accent hover:badge-accent hover:text-accent-content transition-colors cursor-pointer"
                            >
                                {tag}
                            </a>
                        ))}
                    </div>
                )
            }

            <!-- Post list -->
            <div class="grid gap-6">
                {
                    posts.map((post, i) => {
                        const readingTime = getReadingTime(post.body ?? "");
                        const formattedDate = post.data.date.toLocaleDateString(
                            "en-US",
                            {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            }
                        );

                        return (
                            <article
                                class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 border border-base-300 gsap-reveal gsap-up"
                                style={`animation-delay: ${i * 60}ms`}
                            >
                                <div class="card-body">
                                    <h2 class="card-title text-2xl text-secondary hover:text-primary transition-colors">
                                        <a href={`/blog/${post.slug}`}>
                                            {post.data.title}
                                        </a>
                                    </h2>

                                    <div class="flex flex-wrap gap-2 my-2">
                                        {post.data.tags.map((tag) => (
                                            <span class="badge badge-accent badge-outline text-xs">
                                                {tag}
                                            </span>
                                        ))}
                                    </div>

                                    <p class="text-base-content/70 leading-relaxed">
                                        {post.data.description}
                                    </p>

                                    <div class="card-actions justify-between items-center mt-4">
                                        <div class="flex items-center gap-4 text-sm text-base-content/50">
                                            <time datetime={post.data.date.toISOString()}>
                                                {formattedDate}
                                            </time>
                                            <span>·</span>
                                            <span>
                                                {formatReadingTime(readingTime)}
                                            </span>
                                        </div>
                                        <a
                                            href={`/blog/${post.slug}`}
                                            class="btn btn-primary btn-sm"
                                        >
                                            Read More
                                        </a>
                                    </div>
                                </div>
                            </article>
                        );
                    })
                }
            </div>
        </div>
    </div>
</Layout>
