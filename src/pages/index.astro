---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import Skill from "../components/Skill.astro";
import { Image } from "astro:assets";
import profileImage from "../assets/profile.jpg";
import { projects } from "../data/projects";

const featuredProjects = projects.filter((p) => p.featured).slice(0, 3);
---

<Layout>
  <div id="index-page" data-page="index" class="bg-[#0a0a0a]">

    {/* ── Hero ─────────────────────────────────────────── */}
    <section
      id="hero"
      class="relative min-h-screen flex items-center overflow-hidden"
    >
      {/* Noise texture */}
      <div class="absolute inset-0 bg-[url('/noise.svg')] opacity-[0.025] pointer-events-none"></div>

      <div class="container mx-auto px-6 z-10 relative">
        <div class="flex flex-col lg:flex-row items-center justify-between gap-16">

          {/* Content */}
          <div class="flex-1 text-left">

            {/* Status badge */}
            <div data-index-hero="copy" class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/10 border border-green-500/20 mb-10 hero-status">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
              </span>
              <span class="text-xs font-medium text-green-400 tracking-widest uppercase">Available for work</span>
            </div>

            {/* Heading block */}
            <div data-index-hero="copy" class="mb-8 hero-title-1">
              <p class="text-sm font-mono text-gray-600 uppercase tracking-[0.2em] mb-3">Hi, I'm</p>
              <h1 class="text-6xl md:text-7xl lg:text-[6.5rem] font-bold tracking-tight leading-none text-white mb-4">
                Earth<span class="text-green-500">.</span>
              </h1>
              <p class="text-2xl md:text-3xl text-gray-300 font-light tracking-wide hero-title-2">
                Full Stack Developer
              </p>
            </div>

            {/* Description */}
            <p data-index-hero="copy" class="text-base text-gray-500 max-w-md leading-relaxed mb-10 hero-desc">
              React frontends. Node &amp; Django APIs. Cloud infrastructure.<br class="hidden sm:block" />
              Building production-ready apps from Bangkok.
            </p>

            {/* CTAs */}
            <div data-index-hero="copy" class="flex flex-wrap gap-3 hero-buttons">
              <a
                href="#project"
                class="inline-flex items-center gap-2 px-6 py-3 bg-green-500 hover:bg-green-400 text-black text-sm font-semibold rounded-lg transition-colors duration-200 group"
              >
                View Projects
                <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </a>
              <a
                href="/resume.pdf"
                download="resume.pdf"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 border border-white/10 hover:border-white/20 text-gray-400 hover:text-white text-sm font-medium rounded-lg transition-colors duration-200 group"
              >
                <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="12" y1="12" x2="12" y2="18"/>
                  <polyline points="9 15 12 18 15 15"/>
                </svg>
                Resume
              </a>
            </div>
          </div>

          {/* Photo */}
          <div data-index-hero="image" class="flex-shrink-0 flex justify-center lg:justify-end hero-image-container">
            <div class="relative w-72 h-96 sm:w-80 sm:h-[28rem] lg:w-96 lg:h-[32rem] rounded-2xl overflow-hidden border border-white/8">
              <Image
                src={profileImage}
                alt="Earth — Full Stack Developer"
                class="w-full h-full object-cover"
                fetchpriority="high"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
            </div>
          </div>

        </div>
      </div>
    </section>

    {/* ── Featured Work ─────────────────────────────────── */}
    <section id="project" data-index-section class="py-24 bg-[#050505]">
      <div class="container mx-auto px-6">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 data-index-reveal class="text-4xl lg:text-5xl font-bold text-white mb-3">
              Featured <span class="text-green-500">Work</span>
            </h2>
            <div data-index-reveal class="h-px w-16 bg-green-500/50"></div>
          </div>
          <a
            href="/projects"
            data-index-reveal
            class="hidden sm:flex items-center gap-1.5 text-sm text-gray-500 hover:text-white transition-colors duration-200 group"
          >
            View all
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {featuredProjects.map((project) => (
            <div data-index-stagger>
              <Card
                name={project.name}
                desc={project.tagline}
                skill1={project.skills[0]}
                skill2={project.skills[1]}
                skill3={project.skills[2]}
                github={project.github}
                image={project.heroImage}
                slug={project.slug}
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Skills ───────────────────────────────────────── */}
    <section id="skills" data-index-section class="py-24 bg-[#0a0a0a]">
      <div class="container mx-auto px-6">
        <div class="mb-16">
          <h2 data-index-reveal class="text-5xl lg:text-6xl font-bold text-white tracking-tight uppercase mb-3">
            Skills
          </h2>
          <div data-index-reveal class="h-px w-24 bg-green-500/50"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          {/* Frontend */}
          <div data-index-stagger class="border border-white/6 p-6 hover:border-green-500/40 transition-colors duration-300">
            <div class="flex items-start gap-4 mb-6">
              <div class="p-2.5 border border-green-500/20 bg-green-500/5 flex-shrink-0">
                <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-base font-semibold text-white uppercase tracking-wider mb-0.5">Frontend</h3>
                <p class="text-xs font-mono text-gray-600 uppercase">UI / UX / Interaction</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-1.5">
              {["React", "Next.js", "TypeScript", "Tailwind CSS", "Framer Motion", "Svelte", "Zustand", "HTML5", "CSS3", "Sass"].map((skill) => (
                <span class="px-2.5 py-1 border border-white/8 text-gray-500 text-xs font-mono hover:border-green-500/40 hover:text-green-400 transition-colors duration-200">{skill}</span>
              ))}
            </div>
          </div>

          {/* Backend */}
          <div data-index-stagger class="border border-white/6 p-6 hover:border-green-500/40 transition-colors duration-300">
            <div class="flex items-start gap-4 mb-6">
              <div class="p-2.5 border border-green-500/20 bg-green-500/5 flex-shrink-0">
                <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
                </svg>
              </div>
              <div>
                <h3 class="text-base font-semibold text-white uppercase tracking-wider mb-0.5">Backend</h3>
                <p class="text-xs font-mono text-gray-600 uppercase">Server / Database / API</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-1.5">
              {["Node.js", "Express", "NestJS", "Python", "Django", "PostgreSQL", "REST API", "WebSockets", "Supabase"].map((skill) => (
                <span class="px-2.5 py-1 border border-white/8 text-gray-500 text-xs font-mono hover:border-green-500/40 hover:text-green-400 transition-colors duration-200">{skill}</span>
              ))}
            </div>
          </div>

          {/* Tools */}
          <div data-index-stagger class="border border-white/6 p-6 hover:border-green-500/40 transition-colors duration-300">
            <div class="flex items-start gap-4 mb-6">
              <div class="p-2.5 border border-green-500/20 bg-green-500/5 flex-shrink-0">
                <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-base font-semibold text-white uppercase tracking-wider mb-0.5">Tools</h3>
                <p class="text-xs font-mono text-gray-600 uppercase">DevOps / Infra</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-1.5">
              {["Git", "Docker", "Kubernetes", "AWS", "Linux", "CI/CD", "Figma", "Turborepo", "Nginx"].map((skill) => (
                <span class="px-2.5 py-1 border border-white/8 text-gray-500 text-xs font-mono hover:border-green-500/40 hover:text-green-400 transition-colors duration-200">{skill}</span>
              ))}
            </div>
          </div>

          {/* AI / ML */}
          <div data-index-stagger class="border border-white/6 p-6 hover:border-green-500/40 transition-colors duration-300">
            <div class="flex items-start gap-4 mb-6">
              <div class="p-2.5 border border-green-500/20 bg-green-500/5 flex-shrink-0">
                <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v3m0 12v3M3 12h3m12 0h3M7.2 7.2l2.1 2.1m5.4 5.4 2.1 2.1M16.8 7.2l-2.1 2.1M9.3 14.7l-2.1 2.1"/>
                  <circle cx="12" cy="12" r="3.25" />
                </svg>
              </div>
              <div>
                <h3 class="text-base font-semibold text-white uppercase tracking-wider mb-0.5">AI / ML</h3>
                <p class="text-xs font-mono text-gray-600 uppercase">Prompt / Retrieval / Models</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-1.5">
              {["Prompt Engineering", "LLMs", "RAG", "OpenAI API", "LangChain", "Vector Databases", "Hugging Face", "PyTorch", "TensorFlow", "AI Agents", "MLOps"].map((skill) => (
                <span class="px-2.5 py-1 border border-white/8 text-gray-500 text-xs font-mono hover:border-green-500/40 hover:text-green-400 transition-colors duration-200">{skill}</span>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    {/* ── Contact ──────────────────────────────────────── */}
    <section id="contact" data-index-section class="py-24 bg-[#050505]">
      <div class="container mx-auto px-6 max-w-4xl">
        <div data-index-reveal class="border border-white/6 hover:border-green-500/20 transition-colors duration-500 p-8 sm:p-12 lg:p-16">

          <div data-index-stagger class="text-center mb-10">
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-5 tracking-tight">
              Work together.
            </h2>
            <p class="text-base text-gray-500 max-w-md mx-auto leading-relaxed">
              Open to full-time roles and freelance projects.<br class="hidden sm:block" />
              Based in Bangkok, available globally.
            </p>
          </div>

          <div data-index-stagger class="flex justify-center mb-10">
            <a
              href="mailto:jaruvit.rpg@gmail.com"
              class="inline-flex items-center gap-2.5 px-8 py-3.5 bg-green-500 hover:bg-green-400 text-black text-sm font-semibold transition-colors duration-200"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V6C22 4.9 21.1 4 20 4M20 8L12 13L4 8V6L12 11L20 6V8Z"/>
              </svg>
              Send an email
            </a>
          </div>

          <div data-index-stagger class="flex justify-center gap-6">
            <a
              href="https://github.com/heartnet123"
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-600 hover:text-white transition-colors duration-200"
              aria-label="GitHub"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
            <a
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-600 hover:text-white transition-colors duration-200"
              aria-label="Twitter"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
              </svg>
            </a>
            <a
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-600 hover:text-white transition-colors duration-200"
              aria-label="LinkedIn"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>

          <div data-index-stagger class="text-right mt-8">
            <span class="text-xs font-mono text-gray-700 uppercase tracking-wider">v2.0 · heartnet123.github.io</span>
          </div>

        </div>
      </div>
    </section>

  </div>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const rootSelector = "#index-page";

    function cleanupIndexAnimations() {
      const state = (window as any).__indexPageAnimations;
      if (!state) return;

      state.mm?.revert();
      state.ctx?.revert();
      (window as any).__indexPageAnimations = null;
    }

    function getScopedItems(root: Element, selector: string) {
      return gsap.utils.toArray(root.querySelectorAll(selector));
    }

    function showReducedMotionState(targets: Element[]) {
      gsap.set(targets, {
        autoAlpha: 1,
        x: 0,
        y: 0,
        scale: 1,
        clearProps: "transform,opacity,visibility",
      });
    }

    function initIndexAnimations() {
      cleanupIndexAnimations();

      const root = document.querySelector(rootSelector);
      if (!root) return;

      const mm = gsap.matchMedia();
      const ctx = gsap.context(() => {
        mm.add(
          {
            reduceMotion: "(prefers-reduced-motion: reduce)",
            allowMotion: "(prefers-reduced-motion: no-preference)",
          },
          (context) => {
            const reduceMotion = context.conditions?.reduceMotion;
            const heroCopy = getScopedItems(root, "[data-index-hero='copy']");
            const heroImage = getScopedItems(root, "[data-index-hero='image']");
            const revealItems = getScopedItems(root, "[data-index-reveal]");
            const staggerItems = getScopedItems(root, "[data-index-stagger]");

            if (reduceMotion) {
              showReducedMotionState([
                ...heroCopy,
                ...heroImage,
                ...revealItems,
                ...staggerItems,
              ]);
              return;
            }

            gsap.set(heroCopy, { autoAlpha: 0, y: 24 });
            gsap.set(heroImage, { autoAlpha: 0, x: 32, scale: 0.98 });
            gsap.set(revealItems, { autoAlpha: 0, y: 24 });
            gsap.set(staggerItems, { autoAlpha: 0, y: 28, scale: 0.98 });

            gsap
              .timeline({ defaults: { ease: "power3.out", overwrite: "auto" } })
              .to(heroCopy, {
                autoAlpha: 1,
                y: 0,
                duration: 0.65,
                stagger: 0.08,
              })
              .to(
                heroImage,
                {
                  autoAlpha: 1,
                  x: 0,
                  scale: 1,
                  duration: 0.75,
                },
                "-=0.5",
              );

            gsap.utils.toArray("[data-index-section]").forEach((section: any, index) => {
              const sectionRevealItems = gsap.utils.toArray(
                section.querySelectorAll("[data-index-reveal]"),
              );
              const sectionStaggerItems = gsap.utils.toArray(
                section.querySelectorAll("[data-index-stagger]"),
              );

              const sectionTimeline = gsap.timeline({
                defaults: { ease: "power3.out", overwrite: "auto" },
                scrollTrigger: {
                  id: `index-reveal-${section.id || index}`,
                  trigger: section,
                  start: "top 82%",
                  toggleActions: "play none none reverse",
                },
              });

              if (sectionRevealItems.length) {
                sectionTimeline.to(sectionRevealItems, {
                  autoAlpha: 1,
                  y: 0,
                  duration: 0.65,
                  stagger: 0.08,
                });
              }

              if (sectionStaggerItems.length) {
                sectionTimeline.to(
                  sectionStaggerItems,
                  {
                    autoAlpha: 1,
                    y: 0,
                    scale: 1,
                    duration: 0.65,
                    stagger: 0.1,
                  },
                  sectionRevealItems.length ? "-=0.35" : 0,
                );
              }
            });

            ScrollTrigger.refresh();
          },
          root,
        );
      }, root);

      (window as any).__indexPageAnimations = { ctx, mm };
    }

    if (!(window as any).__indexPageAnimationEventsBound) {
      document.addEventListener("astro:page-load", initIndexAnimations);
      document.addEventListener("astro:before-swap", cleanupIndexAnimations);
      (window as any).__indexPageAnimationEventsBound = true;
    }
  </script>
</Layout>
