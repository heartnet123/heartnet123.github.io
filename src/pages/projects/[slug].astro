---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
import type { Project } from "../../data/projects";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<Layout
  title={`${project.name} — JJ Portfolio`}
  description={project.tagline}
>
  <div class="min-h-screen bg-base-100">

    {/* ─────────────────────── Hero ─────────────────────── */}
    <section class="relative h-[55vh] min-h-[360px] overflow-hidden">
      <img
        src={project.heroImage}
        alt={project.name}
        loading="lazy"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-base-100 via-black/60 to-black/20"></div>

      {/* Back button */}
      <a
        href="/projects"
        class="absolute top-6 left-6 lg:left-26 flex items-center gap-2 text-sm text-gray-300 hover:text-green-400 transition-colors group bg-base-100/80 px-4 py-2 rounded-lg border border-white/10 hover:border-green-500/40"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        All Projects
      </a>

      {/* Hero text overlay */}
      <div class="absolute bottom-0 left-0 right-0 px-6 pb-10">
        <div class="max-w-5xl mx-auto">
          <div class="flex flex-wrap gap-2 mb-3">
            {project.skills.map((s) => (
              <span class="px-3 py-1 text-xs font-mono text-green-400 bg-green-500/10 border border-green-500/20 rounded-md">
                {s}
              </span>
            ))}
          </div>
          <h1 class="text-4xl md:text-6xl font-bold text-white mb-3">
            {project.name}
          </h1>
          <p class="text-lg text-gray-300 max-w-2xl">
            {project.tagline}
          </p>
        </div>
      </div>
    </section>

    {/* ─────────────────────── Body ─────────────────────── */}
    <div class="container mx-auto px-6 max-w-5xl py-16 space-y-20">

      {/* CTA Links */}
      <div class="flex flex-wrap gap-4 gsap-reveal gsap-up">
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-white rounded-lg transition-all font-medium"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
        {project.demo && (
          <a
            href={project.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 bg-green-500 hover:bg-green-600 text-black rounded-lg transition-all font-medium"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Live Demo
          </a>
        )}
      </div>

      {/* ── Overview ── */}
      <div class="gsap-reveal gsap-up">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-xs font-mono text-green-500 uppercase tracking-widest">01</span>
          <h2 class="text-2xl font-bold text-white">Overview</h2>
          <div class="flex-1 h-px bg-white/5"></div>
        </div>
        <p class="text-gray-300 text-lg leading-relaxed">{project.description}</p>
      </div>

      {/* ── Problem / Solution ── */}
      <div>
        <div class="flex items-center gap-3 mb-6 gsap-reveal gsap-up">
          <span class="text-xs font-mono text-green-500 uppercase tracking-widest">02</span>
          <h2 class="text-2xl font-bold text-white">Problem &amp; Solution</h2>
          <div class="flex-1 h-px bg-white/5"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-surface border border-white/5 rounded-2xl p-8 gsap-reveal gsap-left">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-8 h-8 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-white">The Problem</h3>
            </div>
            <p class="text-gray-300 leading-relaxed text-sm">{project.problem}</p>
          </div>
          <div class="bg-surface border border-white/5 rounded-2xl p-8 gsap-reveal gsap-right">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-8 h-8 rounded-lg bg-green-500/10 border border-green-500/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-white">The Solution</h3>
            </div>
            <p class="text-gray-300 leading-relaxed text-sm">{project.solution}</p>
          </div>
        </div>
      </div>

      {/* ── Tech Stack ── */}
      <div>
        <div class="flex items-center gap-3 mb-6 gsap-reveal gsap-up">
          <span class="text-xs font-mono text-green-500 uppercase tracking-widest">03</span>
          <h2 class="text-2xl font-bold text-white">Tech Stack</h2>
          <div class="flex-1 h-px bg-white/5"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {project.techStack.map((tech) => (
            <div class="bg-surface border border-white/5 hover:border-green-500/20 rounded-xl p-6 transition-all gsap-reveal gsap-up">
              <span class="inline-block px-3 py-1 text-xs font-mono text-green-400 bg-green-500/10 border border-green-500/20 rounded mb-3">
                {tech.name}
              </span>
              <p class="text-gray-300 text-sm leading-relaxed">{tech.reason}</p>
            </div>
          ))}
        </div>
      </div>

      {/* ── Key Features ── */}
      <div class="gsap-reveal gsap-up">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-xs font-mono text-green-500 uppercase tracking-widest">04</span>
          <h2 class="text-2xl font-bold text-white">Key Features</h2>
          <div class="flex-1 h-px bg-white/5"></div>
        </div>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {project.features.map((feat) => (
            <li class="flex items-start gap-3 text-gray-300">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm leading-relaxed">{feat}</span>
            </li>
          ))}
        </ul>
      </div>

      {/* ── Challenges ── */}
      <div>
        <div class="flex items-center gap-3 mb-6 gsap-reveal gsap-up">
          <span class="text-xs font-mono text-green-500 uppercase tracking-widest">05</span>
          <h2 class="text-2xl font-bold text-white">Challenges &amp; Learnings</h2>
          <div class="flex-1 h-px bg-white/5"></div>
        </div>
        <div class="space-y-4">
          {project.challenges.map((ch, i) => (
            <div class="bg-surface border border-white/5 rounded-xl p-6 gsap-reveal gsap-up">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-mono text-gray-500">#{String(i + 1).padStart(2, "0")}</span>
                <h3 class="font-semibold text-white">{ch.title}</h3>
              </div>
              <p class="text-gray-300 text-sm leading-relaxed">{ch.description}</p>
            </div>
          ))}
        </div>
      </div>

      {/* ── Screenshots ── */}
      {project.screenshots.length > 1 && (
        <div>
          <div class="flex items-center gap-3 mb-6 gsap-reveal gsap-up">
            <span class="text-xs font-mono text-green-500 uppercase tracking-widest">06</span>
            <h2 class="text-2xl font-bold text-white">Screenshots</h2>
            <div class="flex-1 h-px bg-white/5"></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {project.screenshots.map((shot) => (
              <div class="rounded-xl overflow-hidden border border-white/5 bg-surface gsap-reveal gsap-up">
                <img
                  src={shot.src}
                  alt={shot.alt}
                  class="w-full h-auto object-cover"
                  loading="lazy"
                />
                <p class="px-4 py-2 text-xs text-gray-500 font-mono">{shot.alt}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* ── Bottom navigation ── */}
      <div class="pt-6 border-t border-white/5 flex flex-wrap justify-between items-center gap-4 gsap-reveal gsap-up">
        <a
          href="/projects"
          class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors group text-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to all projects
        </a>
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-green-400 hover:text-green-300 transition-colors text-sm font-medium"
        >
          View source on GitHub
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</Layout>
