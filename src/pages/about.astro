---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import profileImage from "../assets/profile.jpg";

const philosophy = [
  {
    label: "01 / SIMPLICITY",
    title: "Simple over Clever",
    body: "Code is read far more than it's written. I favour solutions that a junior developer can understand six months later over impressive one-liners that require a PhD to decipher.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />`,
  },
  {
    label: "02 / OWNERSHIP",
    title: "Ship With Confidence",
    body: "I treat every feature as if I own it end-to-end — from database schema design through API contract, UI polish, and production monitoring. Quality is not a department, it's a mindset.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />`,
  },
  {
    label: "03 / ITERATION",
    title: "Build, Measure, Improve",
    body: "Perfect is the enemy of shipped. I believe in delivering working software early, gathering real feedback, and iterating rapidly — rather than spending months engineering a solution in a vacuum.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />`,
  },
  {
    label: "04 / EMPATHY",
    title: "User-First Thinking",
    body: "Technology exists to serve people. Whether it's a public-facing UI or an internal API, I keep the end-user's experience front-of-mind throughout every architectural decision.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" />`,
  },
];

const education = [
  {
    degree: "Bachelor of Science — Information Technology",
    institution: "King Mongkut's Institute of Technology Ladkrabang (KMITL)",
    period: "2022 – 2026",
    detail:
      "Coursework: Data Structures & Algorithms, Operating Systems, Computer Networks, Database Systems, Software Engineering, Web Development Fundamentals.",
  },
];

const certifications = [
  {
    name: "AWS Cloud Practitioner",
    issuer: "Amazon Web Services",
    year: "2024",
    badge: "AWS",
  },
  {
    name: "Meta Front-End Developer",
    issuer: "Meta / Coursera",
    year: "2023",
    badge: "META",
  },
];

const interests = [
  { label: "OPEN SOURCE", icon: "◈" },
  { label: "MATCHA", icon: "◈" },
  { label: "MECHANICAL KEYBOARDS", icon: "◈" },
  { label: "PIXEL ART", icon: "◈" },
  { label: "SYSTEM DESIGN", icon: "◈" },
  { label: "LINUX", icon: "◈" },
  { label: "GAME DEV", icon: "◈" },
  { label: "AI", icon: "◈" },
  { label: "Cyber Security", icon: "◈" },
];
---

<Layout
  title="About — JJ Portfolio"
  description="Learn about Earth, a full-stack developer focused on AI engineer roles — his background, technical philosophy, education, certifications, and what drives him to build."
>
  <main class="min-h-screen bg-base-100">
    {/* ─── HERO ──────────────────────────────────────────────── */}
    <section class="relative min-h-[60vh] flex items-center bg-base-100 pt-24 pb-16 overflow-hidden">
      {/* Subtle grid background */}
      <div
        class="absolute inset-0 opacity-[0.03]"
        style="background-image: linear-gradient(var(--color-primary) 1px, transparent 1px), linear-gradient(90deg, var(--color-primary) 1px, transparent 1px); background-size: 40px 40px;"
      ></div>

      <div class="container mx-auto px-6 z-10 relative">
        <div class="flex flex-col lg:flex-row items-center gap-16">
          {/* Left — Text */}
          <div class="flex-1 space-y-6 about-hero-text">
            <p class="text-xs font-mono text-green-500 uppercase tracking-widest about-label">
              &gt; whoami
            </p>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white tracking-tight about-title">
              Hey, I'm <span class="text-green-500">Earth</span>
            </h1>
            <p class="text-xl text-gray-300 max-w-xl leading-relaxed about-desc">
              A full-stack developer focused on AI engineer roles, building
              products that combine clean UX, reliable backend systems, and
              practical AI features. Based in Bangkok, currently open to new
              opportunities.
            </p>
            <div class="flex flex-wrap gap-3 about-badges">
              <span class="px-3 py-1 bg-base-200 border border-gray-700 text-green-400 text-xs font-mono">
                • FULL STACK
              </span>
              <span class="px-3 py-1 bg-base-200 border border-gray-700 text-green-400 text-xs font-mono">
                • AI ENGINEER
              </span>
              <span class="px-3 py-1 bg-base-200 border border-gray-700 text-green-400 text-xs font-mono">
                • OPEN TO WORK
              </span>
              <span class="px-3 py-1 bg-base-200 border border-gray-700 text-green-400 text-xs font-mono">
                • BANGKOK, TH
              </span>
            </div>

            <div class="flex flex-wrap gap-4 pt-2 about-cta">
              <a
                href="mailto:jaruvit.rpg@gmail.com"
                class="btn bg-green-500 hover:bg-green-600 text-black border-none rounded-lg px-6 py-3 font-medium capitalize flex items-center gap-2 group"
              >
                Get In Touch
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
              <a
                href="/resume.pdf"
                download="resume.pdf"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-outline border-green-500/40 text-green-400 hover:bg-green-500/10 hover:border-green-500/60 rounded-lg px-6 py-3 font-medium capitalize"
              >
                Download Resume
              </a>
            </div>
          </div>

          {/* Right — Profile image */}
          <div class="flex-shrink-0 about-image">
            <div class="relative">
              <div class="w-64 h-64 lg:w-80 lg:h-80 rounded-2xl overflow-hidden border border-white/10 shadow-2xl">
                <Image
                  src={profileImage}
                  alt="Earth — Full Stack Developer"
                  class="w-full h-full object-cover"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
              </div>
              {/* Floating stat cards */}
              <div class="absolute -bottom-4 -left-4 bg-surface bg-black/80 border border-gray-600 px-4 py-3 rounded-xl">
                <p class="text-2xl font-bold text-green-500">4+</p>
                <p class="text-xs text-gray-300 font-mono uppercase">Yrs Coding</p>
              </div>
              <div class="absolute -top-4 -right-4 bg-surface bg-black/80 border border-gray-600 px-4 py-3 rounded-xl">
                <p class="text-2xl font-bold text-green-500">5+</p>
                <p class="text-xs text-gray-300 font-mono uppercase">Projects</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ─── PROFESSIONAL SUMMARY ──────────────────────────────── */}
    <section class="py-20 bg-base-200">
      <div class="container mx-auto px-6 max-w-5xl">
        <div class="mb-12">
          <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-2 gsap-reveal gsap-left">
            01 / SUMMARY
          </p>
          <h2 class="text-4xl lg:text-5xl font-bold text-white mb-3 gsap-reveal gsap-left">
            Professional <span class="text-green-500">Bio</span>
          </h2>
          <div class="h-1.5 w-20 bg-green-500 rounded-full gsap-reveal gsap-left"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-start">
          <div class="lg:col-span-3 space-y-5 gsap-reveal gsap-up">
            <p class="text-gray-300 leading-relaxed text-lg">
              I'm an Information Technology student at KMITL, and these days I'm
              focusing on AI engineer roles. I care about building products that
              are fast, accessible, and useful, especially when AI can remove
              repetitive work or improve decision-making.
            </p>
            <p class="text-gray-300 leading-relaxed">
              I work across the full stack, but my current interest is in AI
              systems, LLM-powered features, retrieval workflows, and the product
              layer that makes those features actually helpful. My sweet spot is
              the intersection of good UX, clean APIs, and dependable data
              systems.
            </p>
            <p class="text-gray-300 leading-relaxed">
              I'm comfortable jumping into unfamiliar codebases and I enjoy
              improving systems over time — whether that's shaping an AI feature,
              refactoring a legacy module, or introducing better workflows into a
              team that still does things manually.
            </p>
          </div>

          {/* Quick facts terminal card */}
          <div class="lg:col-span-2 gsap-reveal gsap-right">
            <div class="bg-base-100 border border-white/10 rounded-xl overflow-hidden">
              <div class="flex items-center gap-2 px-4 py-3 bg-surface border-b border-white/5">
                <span class="w-3 h-3 rounded-full bg-red-500"></span>
                <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
                <span class="w-3 h-3 rounded-full bg-green-500"></span>
                <span class="ml-2 text-xs text-gray-500 font-mono">profile.json</span>
              </div>
              <div class="p-5 font-mono text-sm space-y-1.5">
                <p><span class="text-purple-400">const</span> <span class="text-blue-400">profile</span> <span class="text-white">=</span> <span class="text-yellow-400">{"{"}</span></p>
                <p class="pl-4"><span class="text-red-400">name</span><span class="text-white">:</span> <span class="text-green-400">'Earth (Jaruvit)'</span><span class="text-white">,</span></p>
                <p class="pl-4"><span class="text-red-400">role</span><span class="text-white">:</span> <span class="text-green-400">'AI Engineer / Full Stack Developer'</span><span class="text-white">,</span></p>
                <p class="pl-4"><span class="text-red-400">location</span><span class="text-white">:</span> <span class="text-green-400">'Bangkok, Thailand'</span><span class="text-white">,</span></p>
                <p class="pl-4"><span class="text-red-400">education</span><span class="text-white">:</span> <span class="text-green-400">'B.Sc IT KMITL'</span><span class="text-white">,</span></p>
                <p class="pl-4"><span class="text-red-400">available</span><span class="text-white">:</span> <span class="text-orange-400">true</span><span class="text-white">,</span></p>
                <p class="pl-4"><span class="text-red-400">matcha</span><span class="text-white">:</span> <span class="text-orange-400">true</span></p>
                <p><span class="text-yellow-400">{"}"}</span><span class="text-white">;</span></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ─── TECHNICAL PHILOSOPHY ──────────────────────────────── */}
    <section class="py-20 bg-base-100">
      <div class="container mx-auto px-6 max-w-6xl">
        <div class="mb-12">
          <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-2 gsap-reveal gsap-left">
            02 / PHILOSOPHY
          </p>
          <h2 class="text-4xl lg:text-5xl font-bold text-white mb-3 gsap-reveal gsap-left">
            How I <span class="text-green-500">Think</span>
          </h2>
          <div class="h-1.5 w-20 bg-green-500 rounded-full gsap-reveal gsap-left"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {philosophy.map((item) => (
            <div class="border border-gray-800 bg-surface p-6 hover:border-green-500/50 transition-all duration-300 group gsap-reveal gsap-up">
              <div class="flex items-start gap-4">
                <div class="p-3 border border-green-500/30 bg-green-500/5 flex-shrink-0 group-hover:bg-green-500/10 transition-colors">
                  <svg
                    class="w-6 h-6 text-green-500"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                    set:html={item.icon}
                  />
                </div>
                <div>
                  <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-1">{item.label}</p>
                  <h3 class="text-lg font-bold text-white mb-2 group-hover:text-green-400 transition-colors">{item.title}</h3>
                  <p class="text-gray-300 text-sm leading-relaxed">{item.body}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ─── EDUCATION ─────────────────────────────────────────── */}
    <section class="py-20 bg-base-200">
      <div class="container mx-auto px-6 max-w-5xl">
        <div class="mb-12">
          <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-2 gsap-reveal gsap-left">
            03 / EDUCATION
          </p>
          <h2 class="text-4xl lg:text-5xl font-bold text-white mb-3 gsap-reveal gsap-left">
            Academic <span class="text-green-500">Background</span>
          </h2>
          <div class="h-1.5 w-20 bg-green-500 rounded-full gsap-reveal gsap-left"></div>
        </div>

        <div class="space-y-6">
          {education.map((edu) => (
            <div class="border border-gray-800 bg-surface p-8 hover:border-green-500/30 transition-all duration-300 gsap-reveal gsap-up">
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-1">
                    <div class="w-2 h-2 bg-green-500 rounded-full flex-shrink-0"></div>
                    <h3 class="text-xl font-bold text-white">{edu.degree}</h3>
                  </div>
                  <p class="text-green-400 font-mono text-sm mb-3 pl-5">{edu.institution}</p>
                  <p class="text-gray-300 text-sm leading-relaxed pl-5">{edu.detail}</p>
                </div>
                <div class="flex-shrink-0 sm:text-right">
                  <span class="inline-flex items-center px-3 py-1 bg-green-500/10 border border-green-500/20 text-green-400 text-xs font-mono rounded-full">
                    {edu.period}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ─── CERTIFICATIONS ────────────────────────────────────── */}
    <!-- <section class="py-20 bg-base-100">
      <div class="container mx-auto px-6 max-w-5xl">
        <div class="mb-12">
          <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-2 gsap-reveal gsap-left">
            04 / CERTIFICATIONS
          </p>
          <h2 class="text-4xl lg:text-5xl font-bold text-white mb-3 gsap-reveal gsap-left">
            Credentials &amp; <span class="text-green-500">Certs</span>
          </h2>
          <div class="h-1.5 w-20 bg-green-500 rounded-full gsap-reveal gsap-left"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {certifications.map((cert) => (
            <div class="border border-gray-800 bg-surface p-6 hover:border-green-500/50 transition-all duration-300 flex items-center gap-5 group gsap-reveal gsap-up">
              <div class="w-14 h-14 border border-green-500/30 bg-green-500/5 flex items-center justify-center flex-shrink-0 group-hover:bg-green-500/10 transition-colors">
                <span class="text-xs font-mono font-bold text-green-500">{cert.badge}</span>
              </div>
              <div>
                <h3 class="text-white font-semibold">{cert.name}</h3>
                <p class="text-gray-500 text-sm font-mono">{cert.issuer}</p>
                <p class="text-green-400 text-xs font-mono mt-1">{cert.year}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section> -->

    {/* ─── INTERESTS ─────────────────────────────────────────── */}
    <section class="py-20 bg-base-200">
      <div class="container mx-auto px-6 max-w-5xl">
        <div class="mb-12">
          <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-2 gsap-reveal gsap-left">
            04 / BEYOND CODE
          </p>
          <h2 class="text-4xl lg:text-5xl font-bold text-white mb-3 gsap-reveal gsap-left">
            Interests &amp; <span class="text-green-500">Passions</span>
          </h2>
          <div class="h-1.5 w-20 bg-green-500 rounded-full gsap-reveal gsap-left"></div>
        </div>

        <div class="gsap-reveal gsap-up">
          <p class="text-gray-300 leading-relaxed mb-8 max-w-2xl">
            When I'm not staring at a terminal, you'll find me sipping of matcha, catching up on the latest AI breakthroughs,
            or losing a few hours to an indie game. I believe that broad curiosity makes a better engineer —
            the best solutions often come from unexpected places.
          </p>

          <div class="flex flex-wrap gap-3">
            {interests.map((item) => (
              <span class="px-4 py-2 bg-surface border border-gray-700 text-green-400 text-sm font-mono hover:border-green-500 hover:bg-green-500/5 transition-all duration-200 cursor-default">
                {item.icon} {item.label}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ─── CTA FOOTER ────────────────────────────────────────── */}
    <section class="py-20 bg-base-100">
      <div class="container mx-auto px-6 max-w-5xl">
        <div class="border border-green-500/30 bg-surface p-12 lg:p-16 relative gsap-reveal gsap-up">
          <div class="text-center">
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-4 uppercase tracking-tight">
              Let's Build Something <span class="text-green-500">Together</span>
            </h2>
            <p class="text-gray-300 max-w-xl mx-auto mb-8 leading-relaxed">
              I'm always open to discussing new projects, creative ideas, or
              opportunities to be part of your vision.
            </p>
            <div class="flex flex-wrap justify-center gap-4">
              <a
                href="mailto:jaruvit.rpg@gmail.com"
                class="btn bg-green-500 hover:bg-green-600 text-black border-none px-8 py-4 font-bold uppercase tracking-wide flex items-center gap-3 hover:scale-105 transition-all duration-300"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V6C22 4.9 21.1 4 20 4M20 8L12 13L4 8V6L12 11L20 6V8Z" />
                </svg>
                Say Hello
              </a>
              <a
                href="/projects"
                class="btn btn-outline border-white/20 text-white hover:bg-white/10 hover:border-white/30 px-8 py-4 font-bold uppercase tracking-wide"
              >
                See My Work
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    import { gsap } from "gsap";

    document.addEventListener("astro:page-load", () => {
      // Page hero entrance animation
      const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
      tl.from(".about-label",  { y: 20, opacity: 0, duration: 0.5 })
        .from(".about-title",  { y: 40, opacity: 0, duration: 0.7 }, "-=0.3")
        .from(".about-desc",   { y: 20, opacity: 0, duration: 0.6 }, "-=0.5")
        .from(".about-badges", { y: 20, opacity: 0, duration: 0.5 }, "-=0.4")
        .from(".about-cta",    { y: 20, opacity: 0, duration: 0.5 }, "-=0.3")
        .from(".about-image",  { x: 40, opacity: 0, duration: 0.8 }, "-=0.8");
    });
  </script>
</Layout>
