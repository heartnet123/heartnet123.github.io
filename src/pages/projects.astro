---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import { projects } from "../data/projects";
---

<Layout
  title="Projects — JJ Portfolio"
  description="A collection of full-stack web and desktop projects built with Next.js, Django, SvelteKit, Tauri, and more."
>
  <section class="min-h-screen bg-base-200 pt-24 px-6">
    <div class="container mx-auto max-w-7xl">
      <h1
        class="text-5xl font-bold text-primary mb-12 text-center gsap-reveal gsap-up"
      >
        My Projects
      </h1>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <Card
            name={project.name}
            desc={project.tagline}
            skill1={project.skills[0]}
            skill2={project.skills[1]}
            skill3={project.skills[2]}
            github={project.github}
            image={project.heroImage}
            slug={project.slug}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>
